APP_NAME=StudHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Manila
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database -----------------------------------------------------------
# Production / staging: MySQL 8 (or MariaDB 11). Local docker compose
# starts a MySQL 8 container exposed on 3306.
# For quick local dev without Docker you can fall back to sqlite.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=studhub
DB_USERNAME=studhub
DB_PASSWORD=studhub

# --- Session / cache / queue -------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=studhub

# --- Redis (used for cache, queue, and Reverb pubsub later) -------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (Mailpit in dev, real SMTP/SES in prod) ----------------------
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@studhub.seait.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- Object storage (S3-compatible: MinIO in dev, R2/S3 in prod) -------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- StudHub-specific ---------------------------------------------------
# School identity (single-tenant SEAIT for v1).
STUDHUB_SCHOOL_NAME="South East Asian Institute of Technology"
STUDHUB_SCHOOL_SHORT="SEAIT"
# Comma-separated allow-list of email domains for sign-up (leave blank
# to disable email-domain restriction).
STUDHUB_ALLOWED_EMAIL_DOMAINS=

VITE_APP_NAME="${APP_NAME}"
